# COM9 Scanner — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# ── Discord ───────────────────────────────────────────────────────────────────
# Token du bot (Developer Portal → Bot → Token)
DISCORD_TOKEN=votre_token_ici

# ID du serveur Discord (clic droit sur le serveur → Copier l'ID)
DISCORD_GUILD_ID=123456789012345678

# Nom du salon pour les résumés de scan
SUMMARY_CHANNEL_NAME=📊︱logs-scanner

# ── Seuil d'alerte ───────────────────────────────────────────────────────────
# Niveau minimum pour déclencher une alerte Discord
# Valeurs possibles : excellent | good | average | risky
MIN_SCORE_ALERT=good

# ── Logs ─────────────────────────────────────────────────────────────────────
# Niveau de log : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
