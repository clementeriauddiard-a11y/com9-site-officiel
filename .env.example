# ─────────────────────────────────────────────────────────
# COM'9 — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local
# Sur Vercel : Settings > Environment Variables
# ─────────────────────────────────────────────────────────

# ── Authentification admin ─────────────────────────────────
# Mot de passe pour accéder à /responsable
ADMIN_PASSWORD=votre_mot_de_passe_ici

# ── Supabase ───────────────────────────────────────────────
# Projet sur https://supabase.com — gratuit
# Settings > API > Project URL + Project API Keys > anon (publishable)

# URL du projet (ex: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé anon/publishable (commence par "sb_publishable_...")
# Settings > API > Project API Keys > anon
SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
