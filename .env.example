# ─────────────────────────────────────────────────────────
# COM'9 — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local
# Sur Vercel : ajouter ces variables dans Settings > Environment Variables
# ─────────────────────────────────────────────────────────

# ── Authentification admin ─────────────────────────────────
# Mot de passe pour accéder à /responsable
# OBLIGATOIRE — le middleware bloque l'accès si absent
ADMIN_PASSWORD=votre_mot_de_passe_ici

# ── Supabase (base de données + images) ──────────────────
# Créer un projet sur https://supabase.com (gratuit)
# Récupérer dans : Settings > API

# URL du projet (ex: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé service role (commence par "eyJ...") — NE JAMAIS exposer côté client
# Settings > API > Project API Keys > service_role
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxx
