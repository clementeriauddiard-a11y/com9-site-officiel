# ─────────────────────────────────────────────────────────
# COM'9 — Variables d'environnement
# Sur Vercel : Settings > Environment Variables
# En local   : copier en .env.local (jamais committer)
# ─────────────────────────────────────────────────────────

# ── Authentification admin ─────────────────────────────────
# Mot de passe pour /responsable — OBLIGATOIRE
ADMIN_PASSWORD=votre_mot_de_passe_ici

# ── Vercel Postgres (base de données téléphones) ───────────
# Vercel Dashboard → Storage → Create → Postgres
# Variables ajoutées automatiquement par Vercel
POSTGRES_URL=postgres://...

# ── Vercel Blob (images des téléphones) ───────────────────
# Vercel Dashboard → Storage → Create → Blob
# Variable ajoutée automatiquement par Vercel
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
