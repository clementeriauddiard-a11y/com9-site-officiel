# ─────────────────────────────────────────────────────────
# COM'9 — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local
# Sur Vercel : ajouter ces variables dans Settings > Environment Variables
# ─────────────────────────────────────────────────────────

# Mot de passe administrateur pour /responsable, /dashboard, /admin
# OBLIGATOIRE — le middleware bloque l'accès si non défini
ADMIN_PASSWORD=votre_mot_de_passe_ici
